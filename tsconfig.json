{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react",
    "lib": ["esnext", "dom"],
    "isolatedModules": true,
    "experimentalDecorators": true,

    "module": "esnext",
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "moduleResolution": "bundler",
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "declaration": true,
    "noImplicitThis": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@wendellhu/redi": ["src/index.ts"],
      "@wendellhu/redi/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx"
  ]
}
